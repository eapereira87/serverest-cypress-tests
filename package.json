{
  "name": "serverest-cypress",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:frontend": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "test:auth": "cypress run --spec \"cypress/e2e/frontend/login*.cy.js,cypress/e2e/frontend/logout.cy.js\"",
    "test:users": "cypress run --spec \"cypress/e2e/frontend/usuarios*.cy.js\"",
    "test:products": "cypress run --spec \"cypress/e2e/frontend/produtos*.cy.js\"",
    "test:smoke": "cypress run --spec \"cypress/e2e/frontend/login.cy.js,cypress/e2e/frontend/usuarios.cy.js,cypress/e2e/frontend/produtos.cy.js\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:report": "npm run report:clean && cypress run",
    "report:merge": "find cypress/reports -maxdepth 1 -name 'mochawesome_*.json' -print0 | xargs -0 npx mochawesome-merge > cypress/reports/mochawesome.json",
    "report:html": "npx marge cypress/reports/mochawesome.json --reportDir cypress/reports/html --reportFilename report",
    "report:generate": "npm run report:merge && npm run report:html",
    "report:clean": "rm -rf cypress/reports && mkdir -p cypress/reports"
  },
  "devDependencies": {
    "cypress": "^14.3.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
