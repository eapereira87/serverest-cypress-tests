{
  "name": "serverest-cypress",
  "version": "1.0.0",
  "description": "Automação de testes frontend e API com Cypress para o desafio do ServeRest",
  "scripts": {
    "cy:open": "cypress open",
    "test": "cypress run",
    "test:frontend": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:chrome": "cypress run --browser chrome"
  },
  "author": "Erick Pereira",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^14.3.0"
  }
}